# Copy this file to .env before running docker compose.

# Hugging Face token for gated Gemma models.
HF_TOKEN=hf_replace_me

# vLLM/Open WebUI settings.
VLLM_IMAGE=vllm/vllm-openai:gemma4-cu130
VLLM_MODEL=nvidia/Gemma-4-31B-IT-NVFP4
VLLM_API_KEY=replace-with-a-random-secret
WEBUI_SECRET_KEY=replace-with-a-random-secret

# Host-side ports on the Spark. These are localhost-only in compose.yaml.
VLLM_HOST_PORT=8000
OPEN_WEBUI_PORT=12010

# Tuning.
VLLM_GPU_MEMORY_UTILIZATION=0.90
MODEL_LIST_TIMEOUT=60

# Smaller/faster single-Spark alternatives:
# VLLM_MODEL=google/gemma-4-E4B-it
# VLLM_MODEL=google/gemma-4-E2B-it
